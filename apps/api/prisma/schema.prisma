generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String      @id @default(uuid())
  phone           String?     @unique
  email           String?     @unique
  name            String
  avatarUrl       String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  contacts        Contact[]
  incidents       Incident[]
  journeys        Journey[]
  sosAlerts       SOSAlert[]
  votes           Vote[]
}

model Contact {
  id        String   @id @default(uuid())
  userId    String
  name      String
  phone     String
  email     String?
  relation  String   // "family" | "friend" | "colleague"
  isActive  Boolean  @default(true)
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Incident {
  id             String        @id @default(uuid())
  userId         String?
  latitude       Float
  longitude      Float
  type           IncidentType
  description    String?
  mediaUrls      String?
  severity       Int           @default(1)  // 1-5 scale
  isAnonymous    Boolean       @default(false)
  verifiedCount  Int           @default(0)
  flaggedCount   Int           @default(0)
  createdAt      DateTime      @default(now())
  expiresAt      DateTime?
  
  user           User?         @relation(fields: [userId], references: [id])
  votes          Vote[]
  
  @@index([latitude, longitude])
  @@index([createdAt])
}

model Vote {
  id          String   @id @default(uuid())
  userId      String
  incidentId  String
  isUpvote    Boolean
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id])
  incident    Incident @relation(fields: [incidentId], references: [id])
  
  @@unique([userId, incidentId])
}

model Journey {
  id             String        @id @default(uuid())
  userId         String
  startLat       Float
  startLng       Float
  destLat        Float?
  destLng        Float?
  destination    String?
  shareToken     String        @unique @default(uuid())
  status         JourneyStatus @default(ACTIVE)
  expectedETA    DateTime?
  startedAt      DateTime      @default(now())
  completedAt    DateTime?
  
  user           User          @relation(fields: [userId], references: [id])
  waypoints      Waypoint[]
}

model Waypoint {
  id          String   @id @default(uuid())
  journeyId   String
  latitude    Float
  longitude   Float
  timestamp   DateTime @default(now())
  
  journey     Journey  @relation(fields: [journeyId], references: [id])
}

model SOSAlert {
  id            String     @id @default(uuid())
  userId        String
  latitude      Float
  longitude     Float
  status        SOSStatus  @default(ACTIVE)
  notifiedCount Int        @default(0)
  resolvedAt    DateTime?
  createdAt     DateTime   @default(now())
  
  user          User       @relation(fields: [userId], references: [id])
}

model RiskZone {
  id          String   @id @default(uuid())
  latitude    Float
  longitude   Float
  radius      Float    // meters
  riskScore   Float    // 0.0 - 1.0
  incidentCount Int
  lastUpdated DateTime @updatedAt
  
  @@index([latitude, longitude])
}

enum IncidentType {
  HARASSMENT
  STALKING
  ASSAULT
  THEFT
  POOR_LIGHTING
  ISOLATED_AREA
  SUSPICIOUS_ACTIVITY
  OTHER
}

enum JourneyStatus {
  ACTIVE
  COMPLETED
  OVERDUE
  SOS_TRIGGERED
}

enum SOSStatus {
  ACTIVE
  RESOLVED
  FALSE_ALARM
}

